# Data directory for JSONL logs and the cached World Cup dataset/API responses
SOCCER_DATA_DIR=./data
# Output directory for World Cup prediction files (JSON + human-friendly report)
SOCCER_PREDICTION_DIR=./perdiction
# Ollama reasoner
SOCCER_OLLAMA_HOST=http://localhost:11434
SOCCER_OLLAMA_MODEL=gemma4:12b-mlx
SOCCER_OLLAMA_TIMEOUT=60
# Provider mode: fixture | http
SOCCER_PROVIDER_MODE=fixture
# Reasoner: fake | ollama
SOCCER_REASONER=fake
# API-Football (API-Sports v3) -- only `soccer wc fetch` needs this. Put the real key in a
# local, git-ignored .env file; never commit it. The base URL rarely needs changing.
SOCCER_API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
SOCCER_API_FOOTBALL_KEY=
